# Copy this file to .env and fill in your Firebase web app values.
# Firebase Console → Project settings → Your apps → Web app → firebaseConfig
#
# Then run:  node scripts/generate-firebase-config.mjs

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin login emails, comma-separated (never committed — generates js/admin-gate.js hashes only)
VITE_ADMIN_EMAIL=admin@example.com,other-admin@example.com

# Frisör admin Firebase UID(s), comma-separated — same login page as customers
VITE_FRISOR_ADMIN_UID=your_firebase_uid_here

# Stripe — https://dashboard.stripe.com/apikeys
# Then run: node scripts/generate-env.mjs
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_STRIPE_CHECKOUT_URL=
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# MailerSend — https://app.mailersend.com/integrations/api
# Ordermejl skickas via MailerSend REST API (inte SMTP)
MAILERSEND_API_KEY=mlsn_your_api_token_here
SMTP_FROM=Afrohörnan <info@afrohornan.com>
ADMIN_ORDER_EMAIL=info@afrohornan.com

# MailerSend course templates (after payment)
MAILERSEND_COURSE_CUSTOMER_TEMPLATE_ID=
MAILERSEND_COURSE_ADMIN_TEMPLATE_ID=
MAILERSEND_DELIVERY_TEMPLATE_ID=jy7zpl9r0o3l5vx6
MAILERSEND_REFUND_TEMPLATE_ID=3vz9dley0o74kj50
MAILERSEND_COURSE_PORTAL_URL=https://afrohornan.com/profile.html
